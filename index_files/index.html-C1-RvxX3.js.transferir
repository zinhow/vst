<style>
:host {
    all: initial !important;
    display: block;
}

.preloader-image {
    width: 100%;
    height: 100%;
}

.preloader-image iframe {
    aspect-ratio: 1 / 1;

    /** Needs to be inverted */
    transform: scaleX(-1);
}
</style>

<div class="preloader-image">
    <iframe
        style="width: 100%; height: 100%; border: none;"
        frameborder="0"
        scrolling="no"
        width="100%"
        height="100%"
    ></iframe>
</div>
