;var _cfg={"apiKey":"tk_live_eD7RN9Fsvig5VhOCrEX7Lcmhio7Uj403","endpoint":"https://hive.vivasorteoficial.com.br","autocapture":true,"discovery":{"enabled":true}};
var _inst=window.hive.init(_cfg.apiKey,{endpoint:_cfg.endpoint,autocapture:_cfg.autocapture,discovery:_cfg.discovery});

/* ── Helpers ─────────────────────────────────────────────── */
var _GTM_INTERNAL=/^gtm\./;
var _SKIP_KEYS={event:1,'gtm.uniqueEventId':1,'gtm.triggers':1,'gtm.start':1,'gtm.scrollThreshold':1,'gtm.scrollUnits':1,'gtm.scrollDirection':1,'gtm.historyChangeSource':1,'gtm.oldUrlFragment':1,'gtm.newUrlFragment':1,'gtm.oldHistoryState':1,'gtm.newHistoryState':1,'gtm.oldUrl':1,'gtm.newUrl':1,'gtm.element':1,'gtm.elementClasses':1,'gtm.elementId':1,'gtm.elementTarget':1,'gtm.elementUrl':1};
var _ECOMMERCE_EVENTS={add_to_cart:1,remove_from_cart:1,begin_checkout:1,add_shipping_info:1,add_payment_info:1,purchase:1,refund:1,view_item:1,view_item_list:1,select_item:1,select_promotion:1,view_promotion:1,view_cart:1};
var _seenDL={};
var _dlSeq=0;

function _cleanProps(obj){
  var out={};
  for(var k in obj){
    if(!obj.hasOwnProperty(k))continue;
    if(_SKIP_KEYS[k]||_GTM_INTERNAL.test(k))continue;
    out[k]=obj[k];
  }
  return out;
}

function _getCookie(n){try{var c='; '+document.cookie;var p=c.split('; '+n+'=');if(p.length===2)return decodeURIComponent(p.pop().split(';')[0]);return null}catch(e){return null}}

function _collectCrossPlatformIds(){
  var ids={};
  var c=_getCookie;
  if(c('_fbp'))ids.fbp=c('_fbp');
  if(c('_fbc'))ids.fbc=c('_fbc');
  if(c('_ga')){var ga=c('_ga');if(ga)ids.ga_client_id=ga.replace(/^GA\d+\.\d+\./,'');}
  if(c('_gcl_au'))ids.gcl_au=c('_gcl_au');
  if(c('kwai_uuid'))ids.kwai_uuid=c('kwai_uuid');
  if(c('_clck'))ids.clarity_id=c('_clck');
  if(c('_twpid'))ids.twitter_pid=c('_twpid');
  if(c('rdtrk')){try{var rd=JSON.parse(decodeURIComponent(c('rdtrk')));if(rd&&rd.id)ids.rdstation_id=rd.id}catch(e){}}
  if(c('_ttp'))ids.tiktok_cookie=c('_ttp');
  try{if(window.OneSignal&&window.OneSignal.getUserId){window.OneSignal.getUserId(function(uid){if(uid)ids.onesignal_player_id=uid})}}catch(e){}
  return ids;
}

/* ── dataLayer Interceptor ───────────────────────────────── */
function _handleDL(raw){
  if(!raw||typeof raw!=='object'||Array.isArray(raw))return;
  if(raw.__cdp_internal)return;

  var ev=raw.event;
  // Skip internal GTM events that Discovery already captures
  if(!ev||ev==='cnt.js')return;
  if(_GTM_INTERNAL.test(ev))return;

  // Deduplicate by gtm.uniqueEventId
  var uid=raw['gtm.uniqueEventId'];
  if(uid&&_seenDL[uid])return;
  if(uid)_seenDL[uid]=1;

  // Clean properties: remove GTM internals
  var props=_cleanProps(raw);

  // Flatten nested 'data' for lm/* events (LuckyMaker app pattern)
  if(props.data&&typeof props.data==='object'){
    var d=props.data;
    for(var dk in d){if(d.hasOwnProperty(dk)&&!props[dk])props[dk]=d[dk]}
  }

  // Tag source
  props._source='dataLayer';
  props._dl_event=ev;
  props._dl_seq=++_dlSeq;

  // Normalize event name: lm/cart/add → cart_add, lm/session/identify → session_identify
  var normalized=ev;
  if(ev.indexOf('lm/')===0){
    normalized=ev.substring(3).replace(/\//g,'_');
  }

  // Auto-identify when user data is present
  if(props.payer||props.user||props.customer){
    var ident=props.payer||props.user||props.customer;
    if(ident.email||ident.phone||ident.document||ident.cpf){
      try{_inst.identify(ident.email||ident.phone||ident.cpf||ident.document,{
        first_name:ident.name||ident.first_name||null,
        email:ident.email||null,
        phone:ident.phone||ident.tel||null,
        cpf:ident.cpf||ident.document||null,
        city:ident.address&&ident.address.city||null,
        state:ident.address&&ident.address.state||null
      })}catch(e){}
    }
  }

  // E-commerce cart state persistence
  if(_ECOMMERCE_EVENTS[normalized]||_ECOMMERCE_EVENTS[ev]){
    var cartEv=_ECOMMERCE_EVENTS[normalized]?normalized:ev;
    if(cartEv!=='purchase'&&cartEv!=='refund'){
      try{localStorage.setItem('cdp_cart_state',JSON.stringify({items:props.items||[],total:props.value||props.total||0,currency:props.currency||'BRL',coupon:props.coupon||null,checkout_step:cartEv,last_updated:Date.now()}))}catch(x){}
    }
    if(cartEv==='purchase'){
      try{localStorage.removeItem('cdp_cart_state');localStorage.removeItem('cdp_cart_exit_time')}catch(x){}
    }
  }

  // Mark as already tracked so Discovery skips it
  raw.__cdp_tracked=true;

  // Track directly through SDK pipeline (same anonymous_id, session_id, profile linkage)
  try{_inst.track(normalized,props)}catch(e){}

  // Auto-register schema in Discovery (fire-and-forget, non-blocking)
  try{
    var _schemaKeys=Object.keys(props).filter(function(k){return k.charAt(0)!=='_'});
    if(_schemaKeys.length>0){
      var _schemaPayload={events:[{raw_payload:raw,page_url:location.href,timestamp:new Date().toISOString(),anonymous_id:_inst.getAnonymousId?_inst.getAnonymousId():''}]};
      var _blob=new Blob([JSON.stringify(_schemaPayload)],{type:'application/json'});
      navigator.sendBeacon(_cfg.endpoint+'/discovery/events?api_key='+_cfg.apiKey,_blob);
    }
  }catch(e){}
}

/* ── cntLayer dispatch (explicit pushes) ─────────────────── */
function _dispatch(e){
if(!e||!e.event||e.event==='cnt.js')return;
var ev=e.event;
if(ev==='identify'){_inst.identify(e.identifier||e.email||e.phone||e.external_id,e.traits||e);}
else if(ev==='group'){_inst.group(e.group_id,e.traits||e);}
else if(ev==='setConsent'||ev==='consent'){_inst.setConsent(e.consent||e);}
else if(ev==='revokeConsent'){_inst.revokeConsent();}
else if(ev==='reset'||ev==='logout'){_inst.reset();}
else{
if(_ECOMMERCE_EVENTS[ev]){
if(ev!=='purchase'&&ev!=='refund'){
try{localStorage.setItem('cdp_cart_state',JSON.stringify({items:e.items||[],total:e.value||e.total||0,currency:e.currency||'BRL',coupon:e.coupon||null,checkout_step:ev,last_updated:Date.now()}))}catch(x){}}
if(ev==='purchase'){try{localStorage.removeItem('cdp_cart_state');localStorage.removeItem('cdp_cart_exit_time')}catch(x){}}}
_inst.track(ev,e);}
}

/* ── Consume cntLayer backlog ─────────────────────────────── */
var _layer=window["cntLayer"]||[];
for(var i=0;i<_layer.length;i++){_dispatch(_layer[i]);}
window["cntLayer"]={push:function(e){_dispatch(e);},_inst:_inst};

/* ── Intercept dataLayer.push() ──────────────────────────── */
var _dl=window.dataLayer=window.dataLayer||[];
// Process existing entries
for(var j=0;j<_dl.length;j++){_handleDL(_dl[j]);}
// Hook future pushes
var _origPush=_dl.push.bind(_dl);
_dl.push=function(){
  var r=_origPush.apply(_dl,arguments);
  for(var k=0;k<arguments.length;k++){_handleDL(arguments[k]);}
  return r;
};

/* ── Collect cross-platform IDs on load ──────────────────── */
setTimeout(function(){
  try{
    var xids=_collectCrossPlatformIds();
    var hasAny=false;
    for(var _k in xids){if(xids.hasOwnProperty(_k)){hasAny=true;break;}}
    if(hasAny){
      xids._source='cnt_loader';
      xids._dl_event='cross_platform_ids';
      xids._dl_seq=++_dlSeq;
      _inst.track('cross_platform_ids',xids);
    }
  }catch(e){}
},2500);

/* ── Aggressive Identity Resolution ──────────────────────── */
var _identified=false;
function _doIdentify(id,traits){
  if(_identified)return;
  _identified=true;
  _inst.identify(id,traits);
}

// Strategy 1: Monitor LuckyMakerState.user (Vue state)
var _identifyInterval=setInterval(function(){
  try{
    var el=document.querySelector('#app');
    if(!el||!el.__vue__)return;
    var vm=el.__vue__;
    var findState=function(c,d){
      if(d>3)return null;
      if(c.LuckyMakerState)return c.LuckyMakerState;
      var ch=c.$children||[];
      for(var i=0;i<ch.length;i++){var f=findState(ch[i],d+1);if(f)return f;}
      return null;
    };
    var lms=findState(vm,0);
    if(!lms)return;
    var u=lms.user;
    if(u&&u.loggedIn&&u.cpf){
      _doIdentify(u.cpf,{cpf:u.cpf,lifecycle_stage:'known',_source:'vue_state'});
    }
    // Track checkout step changes
    if(lms.authentication&&lms.authentication.step){
      var authStep=lms.authentication.step;
      var lastStep=window.__cdp_last_auth_step;
      if(authStep!==lastStep){
        window.__cdp_last_auth_step=authStep;
        _inst.track('checkout_step_changed',{step:authStep,complete:lms.authentication.complete||false});
      }
    }
  }catch(e){}
},2000);
setTimeout(function(){clearInterval(_identifyInterval)},600000);

// Strategy 2: CPF input field monitoring (capture CPF as soon as typed)
var _cpfWatcher=setInterval(function(){
  try{
    var input=document.querySelector('input[name="cpf"],input[placeholder*="CPF"]');
    if(!input||input.__cdp_watched)return;
    input.__cdp_watched=true;
    var lastCpf='';
    input.addEventListener('blur',function(){
      var v=input.value.replace(/[^0-9]/g,'');
      if(v.length===11&&v!==lastCpf){
        lastCpf=v;
        _doIdentify(v,{cpf:v,lifecycle_stage:'lead',_source:'cpf_field'});
        _inst.track('cpf_entered',{cpf_masked:v.substring(0,3)+'.***.***-'+v.substring(9),checkout_step:window.__cdp_last_auth_step||'identification'});
      }
    });
    // Also capture on form submit / button click
    var btn=document.querySelector('button:not([disabled])');
    if(btn){
      var origClick=function(){
        var v=input.value.replace(/[^0-9]/g,'');
        if(v.length===11&&v!==lastCpf){
          lastCpf=v;
          _doIdentify(v,{cpf:v,lifecycle_stage:'lead',_source:'cpf_submit'});
        }
      };
      var cont=input.closest('form')||input.closest('div');
      if(cont){
        cont.addEventListener('click',function(e){
          if(e.target&&e.target.tagName==='BUTTON')origClick();
        });
      }
    }
    clearInterval(_cpfWatcher);
  }catch(e){}
},1000);
setTimeout(function(){clearInterval(_cpfWatcher)},30000);

// Strategy 3: Intercept fetch/XHR responses for auth data
try{
  var _origFetch=window.fetch;
  window.fetch=function(){
    var args=arguments;
    var url=typeof args[0]==='string'?args[0]:(args[0]&&args[0].url)||'';
    var p=_origFetch.apply(this,args);
    // Intercept auth/session/user API responses
    if(/session|auth|login|user|checkout/i.test(url)&&!/collect|analytics|discovery|cnt/i.test(url)){
      p.then(function(r){
        if(!r.ok)return;
        r.clone().json().then(function(data){
          // Look for identity in response
          var d=data&&data.data?data.data:data;
          if(!d)return;
          var email=d.email||d.payer&&d.payer.email||null;
          var phone=d.tel||d.phone||d.payer&&d.payer.phone||null;
          var cpf=d.cpf||d.document||d.payer&&d.payer.document||null;
          var name=d.name||d.full_name||d.payer&&d.payer.name||null;
          if(email||phone||cpf){
            _doIdentify(email||cpf||phone,{
              email:email||null,phone:phone||null,cpf:cpf||null,
              first_name:name||null,lifecycle_stage:'known',_source:'api_response'
            });
          }
        }).catch(function(){});
      }).catch(function(){});
    }
    return p;
  };
}catch(e){}

// Strategy 4: Monitor dataLayer for sign_in/sign_up with enrichment
// Already handled by _handleDL auto-identify, but also check the Vue state
// after sign_in_complete event fires
var _origHandleDL=_handleDL;
_handleDL=function(raw){
  _origHandleDL(raw);
  // After sign-in/sign-up events, force-check Vue state for user data
  if(raw&&raw.event&&/sign.in|sign.up|login|register|auth/i.test(raw.event)){
    setTimeout(function(){
      try{
        var el=document.querySelector('#app');
        if(!el||!el.__vue__)return;
        var vm=el.__vue__;
        var findState=function(c,d){
          if(d>3)return null;
          if(c.LuckyMakerState)return c.LuckyMakerState;
          for(var ch of(c.$children||[])){var f=findState(ch,d+1);if(f)return f;}
          return null;
        };
        var lms=findState(vm,0);
        if(lms&&lms.user&&lms.user.cpf){
          _doIdentify(lms.user.cpf,{cpf:lms.user.cpf,lifecycle_stage:'known',_source:'post_signin_check'});
        }
      }catch(e){}
    },1500);
  }
};

// Strategy 5: Email/phone fields anywhere on the page
var _emailWatcher=setInterval(function(){
  try{
    var inputs=document.querySelectorAll('input[type="email"],input[name*="email"],input[name*="phone"],input[name*="tel"],input[placeholder*="e-mail"],input[placeholder*="telefone"],input[placeholder*="whatsapp"]');
    inputs.forEach(function(input){
      if(input.__cdp_id_watched)return;
      input.__cdp_id_watched=true;
      input.addEventListener('blur',function(){
        var v=input.value.trim();
        if(!v)return;
        if(v.includes('@')&&v.length>5){
          _doIdentify(v,{email:v,lifecycle_stage:'lead',_source:'email_field'});
        }else{
          var digits=v.replace(/[^0-9]/g,'');
          if(digits.length>=10&&digits.length<=15){
            _doIdentify(digits,{phone:digits,lifecycle_stage:'lead',_source:'phone_field'});
          }
        }
      });
    });
  }catch(e){}
},3000);
setTimeout(function(){clearInterval(_emailWatcher)},120000);

/* ── OneSignal Bridge ────────────────────────────────────── */
setTimeout(function(){
  try{
    if(window.OneSignal&&typeof window.OneSignal.getUserId==='function'){
      window.OneSignal.getUserId(function(playerId){
        if(playerId){
          _inst.track('onesignal_subscribed',{onesignal_player_id:playerId,push_permission:Notification.permission||'unknown',_source:'cnt_loader'});
        }
      });
    }else if(window.OneSignalDeferred){
      window.OneSignalDeferred.push(function(os){
        os.getUserId().then(function(pid){
          if(pid)_inst.track('onesignal_subscribed',{onesignal_player_id:pid,push_permission:Notification.permission||'unknown',_source:'cnt_loader'});
        });
      });
    }
  }catch(e){}
},5000);
})();
